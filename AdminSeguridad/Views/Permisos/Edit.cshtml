@model AdminSeguridad.Models.Permiso

<h2>Editar Permiso</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="PermisoID" /> <!-- Campo oculto para el ID -->
    <div class="form-group">
        <label asp-for="NombrePermiso" class="control-label"></label>
        <input asp-for="NombrePermiso" class="form-control" />
        <span asp-validation-for="NombrePermiso" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}